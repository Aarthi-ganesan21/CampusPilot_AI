# ========================================
# Database Configuration
# ========================================
# MongoDB Atlas Connection URI
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
# For local MongoDB: mongodb://127.0.0.1:27017/campuspilot
MONGODB_URI="mongodb+srv://campuspilot_user:campuspilot_password@campuspilot-cluster.mongodb.net/campuspilot?retryWrites=true&w=majority"

# ========================================
# Authentication Configuration
# ========================================
# JWT Secret for signing tokens (should be a strong random string in production)
JWT_SECRET="your_jwt_secret_key_here"

# ========================================
# API Configuration
# ========================================
# Application Port
PORT="3000"

# Node Environment (development, production, test)
NODE_ENV="development"

# ========================================
# AI/LLM Configuration
# ========================================
# Google Gemini API Key for AI features
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# ========================================
# Application URLs
# ========================================
# The URL where this application is hosted (for self-referential links, OAuth callbacks)
APP_URL="http://localhost:3000"

# ========================================
# Logging Configuration
# ========================================
# Log Level (info, debug, warn, error)
LOG_LEVEL="info"
